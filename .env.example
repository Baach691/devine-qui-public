# ===========================================================================
# Modèle de configuration : copie ce fichier en `.env` et remplis les valeurs.
#   cp .env.example .env
# ===========================================================================

# --- Obligatoire ---

# Token du bot (Discord Developer Portal > ton appli > Bot > Reset Token).
# Format : longue chaîne du type MTUxN...XYZ.GxWtxh.iHZ... (~70 caractères).
DISCORD_TOKEN=

# Secret pour signer les liens daily (au moins 32 caractères aléatoires).
# Génère-en un avec : python -c "import secrets; print(secrets.token_urlsafe(32))"
WEBAPP_SECRET=

# --- Optionnel ---

# ID du serveur de test : si renseigné, les commandes slash apparaissent
# instantanément sur ce serveur (sinon la synchro globale prend ~1h).
# Discord > Paramètres > Avancés > Mode développeur, puis clic droit sur le
# serveur > Copier l'identifiant.
GUILD_ID=

# Chemin du fichier de base de données SQLite.
DB_PATH=bot.db

# Règles de filtrage des messages éligibles (longueur min en caractères, en mots).
MIN_CHARS=10
MIN_WORDS=2

# Nombre de messages scannés par salon lors d'un /backfill.
BACKFILL_LIMIT=2000

# Anti-répétition : on évite les N derniers messages tirés (0 = désactivé).
RECENT_PICKS_EXCLUDE=100

# Fuseau horaire utilisé pour le défi quotidien /daily (reset à minuit).
DAILY_TIMEZONE=Europe/Paris

# Heure de pré-calcul du défi du jour (HH:MM, dans DAILY_TIMEZONE).
# À cette heure-là, le bot tire et stocke le défi pour que le premier /daily
# soit instantané. Laisse vide pour désactiver le précalcul (tirage à la volée).
DAILY_PRECOMPUTE_TIME=00:00

# Salon où envoyer l'annonce automatique du nouveau daily (+ ping des joueurs
# de la veille). Si vide, le bot annonce dans le salon où il cherche les messages
# (ALLOWED_CHANNEL_IDS), ou à défaut dans le salon du message tiré du jour.
# Renseigne un ID seulement si tu veux forcer un autre salon.
ANNOUNCE_CHANNEL_ID=

# Date la plus ancienne autorisée pour le tirage aléatoire (format YYYY-MM-DD).
# Le bot choisit une date au hasard entre cette borne et aujourd'hui, puis
# cherche un message proche.
OLDEST_MESSAGE_DATE=2023-10-01

# Restreindre le tirage à certains salons uniquement (IDs séparés par virgules).
# Vide = tous les salons autorisés. Exemple : ALLOWED_CHANNEL_IDS=111111111111111111
ALLOWED_CHANNEL_IDS=

# Liste noire d'utilisateurs (IDs séparés par virgules). Leurs messages ne sont
# ni ingérés ni proposés. Vide = personne en blacklist.
# Exemple : BLACKLIST_USER_IDS=222222222222222222
BLACKLIST_USER_IDS=

# Whitelist par rôle Discord (IDs de rôles, séparés par virgules).
# Si renseigné, seuls les membres ayant au moins un de ces rôles peuvent
# utiliser /daily et les autres commandes. Vide = tout le monde peut jouer.
# Crée un rôle « Joueur Daily » sur ton serveur, attribue-le aux joueurs,
# puis colle ici son ID (clic droit > Copier l'identifiant en mode dev).
# Exemple : ALLOWED_ROLE_IDS=333333333333333333
ALLOWED_ROLE_IDS=

# Comptes Discord autorisés à utiliser le panneau de correction web.
# IDs séparés par des virgules. Vide = panneau admin entièrement désactivé.
ADMIN_USER_IDS=

# --- Interface web (Flask) ---

# Hôte d'écoute :
#   127.0.0.1  → uniquement accessible depuis la même machine (dev local)
#   0.0.0.0    → écoute sur toutes les interfaces réseau (VPS public)
WEBAPP_HOST=127.0.0.1
WEBAPP_PORT=8000
# Une connexion temps réel SSE occupe un thread Waitress.
WEBAPP_THREADS=64

# URL publique du serveur, telle qu'envoyée dans les liens daily.
# En local : http://127.0.0.1:8000
# Sur VPS  : http://TON-IP-OU-DOMAINE:8000  (ou https://... derrière nginx)
WEBAPP_BASE_URL=http://127.0.0.1:8000

# Version H.264/AAC de secours pour les navigateurs qui lisent seulement le son.
# Le VPS doit avoir ffmpeg installé. Le cache reste privé et expire après 48 h.
FFMPEG_PATH=ffmpeg
MEDIA_CACHE_DIR=.media_cache
MEDIA_CACHE_RETENTION_HOURS=48
MEDIA_MAX_TRANSCODE_MB=100

# --- Discord Activity (app embarquée dans Discord, Embedded App SDK) ---------
# CLIENT_ID = Application ID (PUBLIC). Le préfixe VITE_ est OBLIGATOIRE : c'est la
# seule façon dont le build front (Vite) reçoit la valeur. Le backend la lit aussi.
VITE_DISCORD_CLIENT_ID=
# Secret OAuth2 — NE JAMAIS exposer au front, NE JAMAIS commiter. Backend seulement.
DISCORD_CLIENT_SECRET=
